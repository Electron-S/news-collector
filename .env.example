TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# (선택) 구독 채널 중요 소식 수집 — 봇이 아니라 내 계정(MTProto)으로 읽는다.
# 1) https://my.telegram.org → API development tools 에서 발급
TG_API_ID=
TG_API_HASH=
# 2) `node tg-login.js` 로 1회 로그인 후 출력되는 세션 문자열을 붙여넣는다(외부 공유 금지)
TG_SESSION=
# (선택) 수집 범위 조정
TG_HOURS=24
TG_PER_CHANNEL=20
TG_MAX_MESSAGES=60
